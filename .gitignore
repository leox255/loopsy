# Backup files left by daemon config rewrites and editors.
*.bak
*.swp
*~

# Synced at build time by scripts/sync-worker.mjs — included in the published
# tarball via package.json `files`, but not committed to the repo.
packages/deploy-relay/worker/

# Flutter / Xcode build artifacts (apps/mobile)
apps/mobile/.dart_tool/
apps/mobile/build/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/ios/Flutter/Flutter.framework/
apps/mobile/ios/Flutter/Flutter.podspec

# Android signing — never commit (Play Store rejects compromised keys + locked listing)
apps/mobile/android/key.properties
*.jks
*.keystore
