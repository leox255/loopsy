{
  "name": "loopsy",
  "version": "1.0.53",
  "private": true,
  "description": "Control your terminal from your phone. Self-hosted on Cloudflare Workers.",
  "scripts": {
    "setup": "pnpm install && pnpm build && node packages/cli/dist/index.js init",
    "sync-version": "node scripts/sync-version.mjs",
    "build": "node scripts/sync-version.mjs && pnpm -r --filter=@loopsy/protocol build && pnpm -r --filter=@loopsy/discovery build && pnpm -r --filter=!@loopsy/protocol --filter=!@loopsy/discovery build",
    "loopsy": "node packages/cli/dist/index.js",
    "start": "node packages/daemon/dist/main.js",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "esbuild"
    ],
    "overrides": {
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.25",
      "qs": ">=6.15.2",
      "ip-address": ">=10.1.1",
      "brace-expansion": ">=5.0.6",
      "vite": ">=6.4.2",
      "rollup": ">=4.59.0",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10",
      "ws": ">=8.20.1",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0 <8.0.0",
      "undici@>=8.0.0 <8.5.0": ">=8.5.0 <9.0.0"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
